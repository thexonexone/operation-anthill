class SQLiteMemory:
    def __init__(self, db_path: str = "data/anthill_memory.db"):
        self.db_path = str((SCRIPT_DIR / db_path).resolve())
        Path(self.db_path).parent.mkdir(parents=True, exist_ok=True)
        self._init_db()

    def _connect(self):
        return sqlite3.connect(self.db_path)

    def _init_db(self):
        with self._connect() as conn:
            cursor = conn.cursor()

            cursor.execute("""
                CREATE TABLE IF NOT EXISTS missions (
                    id TEXT PRIMARY KEY,
                    goal TEXT NOT NULL,
                    status TEXT NOT NULL,
                    final_result TEXT,
                    success_score REAL,
                    created_at TEXT NOT NULL,
                    saved_at TEXT NOT NULL
                )
            """)

            cursor.execute("""
                CREATE TABLE IF NOT EXISTS tasks (
                    id TEXT PRIMARY KEY,
                    mission_id TEXT NOT NULL,
                    title TEXT NOT NULL,
                    description TEXT NOT NULL,
                    assigned_ant TEXT NOT NULL,
                    status TEXT NOT NULL,
                    result TEXT,
                    FOREIGN KEY (mission_id) REFERENCES missions(id)
                )
            """)

            conn.commit()

    def save_mission(self, mission: Mission):
        with self._connect() as conn:
            cursor = conn.cursor()

            cursor.execute("""
                INSERT OR REPLACE INTO missions (
                    id, goal, status, final_result, success_score, created_at, saved_at
                )
                VALUES (?, ?, ?, ?, ?, ?, ?)
            """, (
                mission.id,
                mission.goal,
                mission.status.value,
                mission.final_result,
                mission.success_score,
                mission.created_at.isoformat(),
                datetime.now(timezone.utc).isoformat(),
            ))

            for task in mission.tasks:
                cursor.execute("""
                    INSERT OR REPLACE INTO tasks (
                        id, mission_id, title, description, assigned_ant, status, result
                    )
                    VALUES (?, ?, ?, ?, ?, ?, ?)
                """, (
                    task.id,
                    mission.id,
                    task.title,
                    task.description,
                    task.assigned_ant,
                    task.status.value,
                    task.result,
                ))

            conn.commit()

    def get_recent_missions(self, limit: int = 5) -> List[Dict[str, str]]:
        with self._connect() as conn:
            conn.row_factory = sqlite3.Row
            cursor = conn.cursor()

            cursor.execute("""
                SELECT id, goal, status, final_result, success_score, created_at, saved_at
                FROM missions
                ORDER BY saved_at DESC
                LIMIT ?
            """, (limit,))

            rows = cursor.fetchall()
            return [dict(row) for row in rows]

    def format_recent_memory(self, limit: int = 3, max_result_chars: int = 300) -> str:
        recent_missions = self.get_recent_missions(limit=limit)

        if not recent_missions:
            return "No previous mission memory found."

        memory_blocks = []

        for mission in recent_missions:
            score = mission.get("success_score")
            score_line = f"Previous Pheromone Score: {score}" if score is not None else ""

            result_summary = mission.get("final_result") or ""
            result_summary = truncate_text(
                result_summary,
                max_result_chars,
                suffix="...[memory result truncated]",
            )

            block = (
                f"Previous Goal: {mission.get('goal')}\n"
                f"Previous Status: {mission.get('status')}\n"
            )

            if score_line:
                block += f"{score_line}\n"

            block += f"Previous Result Summary:\n{result_summary}\n"
            memory_blocks.append(block)

        return "\n---\n".join(memory_blocks)


