#  PLANNER
# ============================================================

class Planner:
    ALLOWED_ANTS = {"researcher", "builder", "verifier"}

    def __init__(self, use_ollama: bool = USE_OLLAMA, llm: Optional[OllamaClient] = None):
        self.use_ollama = use_ollama
        self.llm = llm

    def create_tasks(self, goal: str, memory_context: str = "", tool_context: str = "") -> List[Task]:
        if not self.use_ollama or self.llm is None:
            return self._fallback_tasks(goal)

        prompt = f"""
You are the Planner inside ANTHILL, a local swarm-intelligence AI harness.

ANTHILL has these available ants only:
- researcher: gathers context, reviews memory, frames the mission, and can use safe read-only tools through the Queen.
- builder: creates the main answer, code, plan, commands, or solution.
- verifier: checks output quality, missing steps, and failure risks.

Available tools:
{tool_context}

Mission goal:
{goal}

Recent memory context:
{memory_context}

Your job:
Create a mission-specific task plan.

Rules:
- Return ONLY valid JSON.
- Do not include markdown.
- Do not include explanations outside the JSON.
- Create between {MIN_DYNAMIC_TASKS} and {MAX_DYNAMIC_TASKS} tasks.
- Every task must use one of these assigned_ant values only: researcher, builder, verifier.
- The final task should usually be assigned to verifier.
- Use more than one builder task only if the mission needs multiple build phases.
- Do not assign shell execution unless shell tools are explicitly enabled.

Required JSON format:
{{
  "tasks": [
    {{
      "title": "Short task title",
      "description": "Clear task description",
      "assigned_ant": "researcher"
    }},
    {{
      "title": "Short task title",
      "description": "Clear task description",
      "assigned_ant": "builder"
    }},
    {{
      "title": "Short task title",
      "description": "Clear task description",
      "assigned_ant": "verifier"
    }}
  ]
}}
"""

        response = self.llm.generate(prompt)

        if response.startswith("ERROR:"):
            print(f"[red]Planner failed to use Ollama:[/red] {response}")
            print("[yellow]Using fallback static task plan.[/yellow]")
            return self._fallback_tasks(goal)

        try:
            parsed = self._parse_json_response(response)
            tasks = self._tasks_from_json(parsed, goal)

            if not tasks:
                print("[yellow]Dynamic planner returned no valid task plan. Using fallback plan.[/yellow]")
                return self._fallback_tasks(goal)

            print("[bold blue]Dynamic planner created mission-specific tasks.[/bold blue]")
            return tasks

        except Exception as error:
            print(f"[yellow]Dynamic planner parse failed:[/yellow] {error}")
            print("[yellow]Using fallback static task plan.[/yellow]")
            return self._fallback_tasks(goal)

    def _parse_json_response(self, response: str) -> Dict[str, Any]:
        cleaned = response.strip()

        if cleaned.startswith("```"):
            cleaned = re.sub(r"^```(?:json)?", "", cleaned, flags=re.IGNORECASE).strip()
            cleaned = re.sub(r"```$", "", cleaned).strip()

        try:
            return json.loads(cleaned)
        except json.JSONDecodeError:
            match = re.search(r"\{.*\}", cleaned, re.DOTALL)

            if not match:
                raise ValueError("No JSON object found in planner response.")

            return json.loads(match.group(0))

    def _tasks_from_json(self, parsed: Dict[str, Any], goal: str) -> List[Task]:
        raw_tasks = parsed.get("tasks")

        if raw_tasks is None:
            print("[yellow]Planner JSON missing 'tasks' key.[/yellow]")
            return []

        if not isinstance(raw_tasks, list):
            print("[yellow]Planner JSON 'tasks' value is not a list.[/yellow]")
            return []

        tasks = []
        dropped_tasks = 0

        for item in raw_tasks[:MAX_DYNAMIC_TASKS]:
            if not isinstance(item, dict):
                dropped_tasks += 1
                continue

            title = str(item.get("title", "")).strip()
            description = str(item.get("description", "")).strip()
            assigned_ant = str(item.get("assigned_ant", "")).strip().lower()

            if assigned_ant not in self.ALLOWED_ANTS:
                dropped_tasks += 1
                print(
                    f"[yellow]Dropped planner task with invalid ant:[/yellow] "
                    f"{assigned_ant or 'missing'}"
                )
                continue

            if not title:
                title = f"{assigned_ant.title()} task"

            if not description:
                description = f"Handle part of the mission: {goal}"

            tasks.append(
                Task(
                    title=title,
                    description=description,
                    assigned_ant=assigned_ant,
                )
            )

        if dropped_tasks:
            print(f"[yellow]Planner dropped {dropped_tasks} invalid task(s).[/yellow]")

        if len(tasks) < MIN_DYNAMIC_TASKS:
            print(
                f"[yellow]Planner produced only {len(tasks)} valid task(s); "
                f"minimum is {MIN_DYNAMIC_TASKS}.[/yellow]"
            )
            return []

        if not any(task.assigned_ant == "verifier" for task in tasks):
            print("[yellow]Planner did not include verifier task. Adding one.[/yellow]")
            tasks.append(
                Task(
                    title="Verify mission output",
                    description=f"Check the final result for accuracy, completeness, and usefulness: {goal}",
                    assigned_ant="verifier",
                )
            )

        return tasks[:MAX_DYNAMIC_TASKS]

    def _fallback_tasks(self, goal: str) -> List[Task]:
        return [
            Task(
                title="Research mission",
                description=f"Understand the goal and gather useful context: {goal}",
                assigned_ant="researcher",
            ),
            Task(
                title="Build response",
                description=f"Create a practical answer or action plan for: {goal}",
                assigned_ant="builder",
            ),
            Task(
                title="Verify result",
                description=f"Check the result for accuracy, usefulness, and missing steps: {goal}",
                assigned_ant="verifier",
            ),
        ]


# ============================================================
#  PHEROMONE ENGINE
# ============================================================

class PheromoneEngine:
    QUALITY_BONUS_THRESHOLD = 1500

    def score_mission(self, mission: Mission) -> float:
        total_tasks = len(mission.tasks)

        if total_tasks == 0:
            return 0.0

        completed_tasks = [
            task for task in mission.tasks
            if task.status == TaskStatus.COMPLETE
        ]

        failed_tasks = [
            task for task in mission.tasks
            if task.status == TaskStatus.FAILED
        ]

        builder_results = [
            task.result for task in mission.tasks
            if task.assigned_ant == "builder" and task.result
        ]

        verifier_results = [
            task.result for task in mission.tasks
            if task.assigned_ant == "verifier" and task.result
        ]

        builder_output = "\n".join(builder_results)
        verifier_output = "\n".join(verifier_results).lower()

        completion_score = len(completed_tasks) / total_tasks
        failure_penalty = len(failed_tasks) * 0.25

        score = completion_score - failure_penalty

        if len(builder_output) > self.QUALITY_BONUS_THRESHOLD:
            score += 0.10

        if "verification failed" in verifier_output:
            score -= 0.25

        if "needs improvement" in verifier_output:
            score -= 0.10

        if "verification passed" in verifier_output:
            score += 0.05

        return max(0.0, min(1.0, round(score, 2)))


# ============================================================
#  ANTS
# ============================================================

class BaseAnt(ABC):
    def __init__(self, name: str):
        self.name = name

    @abstractmethod
    def run(self, task: Task, mission: Mission) -> str:
        pass


class ResearcherAnt(BaseAnt):
    def __init__(self, memory: SQLiteMemory, tools: ToolRegistry):
        super().__init__(name="researcher")
        self.memory = memory
        self.tools = tools

    def run(self, task: Task, mission: Mission) -> str:
        recent_memory = self.memory.format_recent_memory(limit=3, max_result_chars=500)

        tool_results = [self.tools.run_tool("system_info")]

        if self._should_inspect_workspace(task, mission):
            tool_results.append(self.tools.run_tool("list_directory", path="."))

        tool_report = self._format_tool_report(tool_results)

        return (
            f"Researcher Ant reviewed the current mission, recent memory, and relevant safe context.\n\n"
            f"Current Mission:\n{mission.goal}\n\n"
            f"Assigned Task:\n{task.description}\n\n"
            f"Recent Memory:\n{recent_memory}\n\n"
            f"Tool Context:\n{tool_report}\n\n"
            f"Research Finding:\n"
            f"The mission should be handled through specialized task execution, verified, "
            f"scored with pheromone strength, and saved into memory so future missions can improve. "
            f"Only safe read-only tools are currently available unless shell execution is explicitly enabled."
        )

    def _should_inspect_workspace(self, task: Task, mission: Mission) -> bool:
        text = f"{mission.goal} {task.title} {task.description}".lower()

        keywords = [
            "file",
            "files",
            "folder",
            "folders",
            "directory",
            "directories",
            "workspace",
            "project",
            "code",
            "script",
            "python",
            "repo",
            "repository",
            "debug",
            "error",
            "log",
            "logs",
            "config",
            "read",
            "inspect",
            "list",
            "show",
            "what's here",
            "whats here",
            "what is here",
            "what's in",
            "whats in",
            "look at",
            "open",
            "tree",
            "structure",
        ]

        return any(keyword in text for keyword in keywords)

    def _format_tool_report(self, results: List[ToolResult]) -> str:
        blocks = []

        for result in results:
            if result.success:
                blocks.append(
                    f"Tool: {result.tool_name}\n"
                    f"Success: {result.success}\n"
                    f"Output:\n{result.output}"
                )
            else:
                blocks.append(
                    f"Tool: {result.tool_name}\n"
                    f"Success: {result.success}\n"
                    f"Error:\n{result.error}"
                )

        return "\n\n---\n\n".join(blocks)


class BuilderAnt(BaseAnt):
    def __init__(self, use_ollama: bool = USE_OLLAMA, llm: Optional[OllamaClient] = None):
        super().__init__(name="builder")
        self.use_ollama = use_ollama
        self.llm = llm

    def run(self, task: Task, mission: Mission) -> str:
        previous_results = [
            f"{t.assigned_ant.upper()} - {t.title}:\n{t.result}"
            for t in mission.tasks
            if t.result
        ]

        previous_context = (
            "\n\n".join(previous_results)
            if previous_results
            else "No previous task context available."
        )

        previous_context = truncate_text(
            previous_context,
            MAX_PREVIOUS_CONTEXT_CHARS,
            suffix="...[previous context truncated]",
        )

        if not self.use_ollama or self.llm is None:
            return self._fallback_response(task, mission, previous_context)

        prompt = f"""
You are Builder Ant inside ANTHILL, a local swarm-intelligence AI harness.

ANTHILL concept:
A Queen agent receives a user mission, creates tasks, assigns specialized ant agents,
collects the results, verifies the output, assigns a pheromone success score, and stores memory for future missions.

Mission goal:
{mission.goal}

Your assigned task:
{task.title}
{task.description}

Previous task context:
{previous_context}

Your job:
Complete only your assigned builder task while supporting the overall mission.

Rules:
- Be direct.
- Be structured.
- Do not pretend to do things you cannot actually do.
- If commands, code, or steps are needed, include them.
- Keep the answer useful for someone building or using a local AI harness.
- If tools are needed, describe the tool request rather than assuming direct access.
"""

        response = self.llm.generate(prompt)

        if response.startswith("ERROR:"):
            fallback = self._fallback_response(task, mission, previous_context)
            return (
                f"{response}\n\n"
                f"Fallback Builder Response:\n{fallback}"
            )

        return response

    def _fallback_response(self, task: Task, mission: Mission, previous_context: str) -> str:
        return (
            f"Builder Ant created a basic non-LLM response.\n\n"
            f"Mission Goal:\n{mission.goal}\n\n"
            f"Assigned Task:\n{task.title}\n{task.description}\n\n"
            f"Previous Context:\n{previous_context}\n\n"
            f"Proposed Output:\n"
            f"1. Understand the mission.\n"
            f"2. Execute the assigned builder task.\n"
            f"3. Use previous task context when useful.\n"
            f"4. Produce a practical result.\n"
            f"5. Leave enough detail for the verifier to check."
        )


class VerifierAnt(BaseAnt):
    def __init__(self, use_ollama: bool = USE_OLLAMA, llm: Optional[OllamaClient] = None):
        super().__init__(name="verifier")
        self.use_ollama = use_ollama
        self.llm = llm

    def run(self, task: Task, mission: Mission) -> str:
        # Exclude only this verifier task, not all verifier tasks.
        # This allows future missions to support more than one verifier.
        prior_tasks = [t for t in mission.tasks if t.id != task.id]

        completed_tasks = [t for t in prior_tasks if t.status == TaskStatus.COMPLETE]
        failed_tasks = [t for t in prior_tasks if t.status == TaskStatus.FAILED]
        builder_tasks = [t for t in prior_tasks if t.assigned_ant == "builder" and t.result]

        static_check = self._static_verify(completed_tasks, failed_tasks, builder_tasks)

        if not self.use_ollama or self.llm is None:
            return static_check

        verification_context = self._build_verification_context(mission, prior_tasks)

        prompt = f"""
You are Verifier Ant inside ANTHILL, a local swarm-intelligence AI harness.

Your job:
Evaluate whether the mission output is useful, complete, and aligned with the original mission.

Mission goal:
{mission.goal}

Assigned verification task:
{task.title}
{task.description}

Static system check:
{static_check}

Task outputs to verify:
{verification_context}

Return a concise verification report.

Required format:
- Verdict: Verification Passed / Needs Improvement / Verification Failed
- Reasoning: brief explanation
- Missing Steps: list any missing items, or "None"
- Risk Notes: list risks, hallucinations, unsafe assumptions, or "None"

Rules:
- Be strict but fair.
- Do not invent facts.
- Judge the output against the mission goal.
- If the builder did not actually answer the mission, say so.
"""

        response = self.llm.generate(prompt)

        if response.startswith("ERROR:"):
            return (
                f"{static_check}\n\n"
                f"LLM verifier unavailable:\n{response}"
            )

        return response

    def _static_verify(
        self,
        completed_tasks: List[Task],
        failed_tasks: List[Task],
        builder_tasks: List[Task],
    ) -> str:
        if failed_tasks:
            return (
                "Verification Failed\n"
                "Reasoning: One or more tasks failed before verification.\n"
                "Missing Steps: Resolve failed task output before finalizing.\n"
                "Risk Notes: Mission may be incomplete or partially invalid."
            )

        if not builder_tasks:
            return (
                "Verification Failed\n"
                "Reasoning: No builder output was found to verify.\n"
                "Missing Steps: Builder output is required.\n"
                "Risk Notes: Mission result may be empty or incomplete."
            )

        if len(completed_tasks) >= 2:
            return (
                "Verification Passed\n"
                "Reasoning: Mission has completed task output and at least one builder result.\n"
                "Missing Steps: None identified by static verification.\n"
                "Risk Notes: Static verification does not evaluate factual content."
            )

        return (
            "Needs Improvement\n"
            "Reasoning: Mission may not have enough completed task output.\n"
            "Missing Steps: More task output may be needed before finalizing.\n"
            "Risk Notes: Output may be incomplete."
        )

    def _build_verification_context(self, mission: Mission, prior_tasks: List[Task]) -> str:
        blocks = []

        for item in prior_tasks:
            blocks.append(
                f"Task: {item.title}\n"
                f"Ant: {item.assigned_ant}\n"
                f"Status: {item.status.value}\n"
                f"Result:\n{item.result}\n"
            )

        context = "\n---\n".join(blocks)

        return truncate_text(
            context,
            MAX_VERIFIER_CONTEXT_CHARS,
            suffix="...[verification context truncated]",
        )


