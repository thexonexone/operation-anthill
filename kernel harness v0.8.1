class Planner:
    ALLOWED_ANTS = {"researcher", "file", "coder", "builder", "verifier"}

    def __init__(self, use_ollama: bool = USE_OLLAMA, llm: Optional[OllamaClient] = None):
        self.use_ollama = use_ollama
        self.llm = llm

    def create_tasks(
        self,
        goal: str,
        memory_context: str = "",
        tool_context: str = "",
        pheromone_context: str = "",
    ) -> List[Task]:
        if not self.use_ollama or self.llm is None:
            return self._fallback_tasks(goal)

        prompt = f"""
You are the Planner inside ANTHILL, a local swarm-intelligence AI harness.

ANTHILL has these available ants only:
- researcher: gathers context, reviews memory, frames the mission, and can use safe read-only tools through the Queen.
- file: inspects safe workspace files, lists project structure, and reads allowed text files. Read-only only.
- coder: reviews code context and proposes structured patch proposals as JSON. It does not write files.
- builder: creates the main answer, code plan, commands, or solution from previous ant output.
- verifier: checks output quality, missing steps, and failure risks.

Available tools:
{tool_context}

Recent and relevant memory:
{memory_context}

Pheromone trail memory:
{pheromone_context}

How to use pheromone trail memory:
- Higher strength means that ant path, task type, tool, or planner pattern has historically worked better.
- Lower strength means it has failed more often or been less useful.
- Prefer high-strength trails when they fit the current mission.
- Avoid low-strength trails when a better matching route exists.
- Use pheromone memory as routing guidance, not as a hard rule.
- Do not blindly follow pheromone trails if they do not match the current mission.

Mission goal:
{goal}

Your job:
Create a mission-specific task plan.

Rules:
- Return ONLY valid JSON.
- Do not include markdown.
- Do not include explanations outside the JSON.
- Create between {MIN_DYNAMIC_TASKS} and {MAX_DYNAMIC_TASKS} tasks.
- Every task must use one of these assigned_ant values only: researcher, file, coder, builder, verifier.
- Every task should include a task_type.
- The final task should usually be assigned to verifier.
- Use the file ant for missions involving files, folders, project structure, scripts, codebases, or repo inspection.
- Use the coder ant for missions involving code review, bugs, architecture, refactors, patches, or Python scripts.
- Do not assign shell execution unless shell tools are explicitly enabled.
- Do not ask any ant to write files yet.
- Leave depends_on empty for now unless exact prior task IDs are known.
- This runner executes tasks sequentially.
- depends_on only works for tasks that already appeared earlier in the task list.
- Since task IDs are usually generated after planning, depends_on should usually be [] in this version.

Allowed task_type examples:
research, file_inspection, code_review, patch_proposal, build_answer, verification, general

Required JSON format:
{{
  "tasks": [
    {{
      "title": "Short task title",
      "description": "Clear task description",
      "assigned_ant": "researcher",
      "task_type": "research",
      "depends_on": []
    }},
    {{
      "title": "Short task title",
      "description": "Clear task description",
      "assigned_ant": "builder",
      "task_type": "build_answer",
      "depends_on": []
    }},
    {{
      "title": "Short task title",
      "description": "Clear task description",
      "assigned_ant": "verifier",
      "task_type": "verification",
      "depends_on": []
    }}
  ]
}}
"""

        response = self.llm.generate(prompt)

        if response.startswith("ERROR:"):
            print(f"[red]Planner failed to use Ollama:[/red] {response}")
            print("[yellow]Using fallback static task plan.[/yellow]")
            return self._fallback_tasks(goal)

        try:
            parsed = extract_json_object(response)
            tasks = self._tasks_from_json(parsed, goal)

            if not tasks:
                print("[yellow]Dynamic planner returned no valid task plan. Using fallback plan.[/yellow]")
                return self._fallback_tasks(goal)

            print("[bold blue]Dynamic planner created mission-specific tasks.[/bold blue]")
            return tasks

        except Exception as error:
            print(f"[yellow]Dynamic planner parse failed:[/yellow] {error}")
            print("[yellow]Using fallback static task plan.[/yellow]")
            return self._fallback_tasks(goal)

    def _tasks_from_json(self, parsed: Dict[str, Any], goal: str) -> List[Task]:
        raw_tasks = parsed.get("tasks")

        if raw_tasks is None:
            print("[yellow]Planner JSON missing 'tasks' key.[/yellow]")
            return []

        if not isinstance(raw_tasks, list):
            print("[yellow]Planner JSON 'tasks' value is not a list.[/yellow]")
            return []

        tasks = []
        dropped_tasks = 0

        for item in raw_tasks[:MAX_DYNAMIC_TASKS]:
            if not isinstance(item, dict):
                dropped_tasks += 1
                continue

            title = str(item.get("title", "")).strip()
            description = str(item.get("description", "")).strip()
            assigned_ant = str(item.get("assigned_ant", "")).strip().lower()

            if assigned_ant not in self.ALLOWED_ANTS:
                dropped_tasks += 1
                print(
                    f"[yellow]Dropped planner task with invalid ant:[/yellow] "
                    f"{assigned_ant or 'missing'}"
                )
                continue

            if not title:
                title = f"{assigned_ant.title()} task"

            if not description:
                description = f"Handle part of the mission: {goal}"

            task_type = str(item.get("task_type", "")).strip().lower()
            if not task_type:
                task_type = infer_task_type(assigned_ant, title, description)

            depends_on = item.get("depends_on", [])
            if not isinstance(depends_on, list):
                depends_on = []

            tasks.append(
                Task(
                    title=title,
                    description=description,
                    assigned_ant=assigned_ant,
                    task_type=task_type,
                    depends_on=[str(x) for x in depends_on],
                )
            )

        if dropped_tasks:
            print(f"[yellow]Planner dropped {dropped_tasks} invalid task(s).[/yellow]")

        if len(tasks) < MIN_DYNAMIC_TASKS:
            print(
                f"[yellow]Planner produced only {len(tasks)} valid task(s); "
                f"minimum is {MIN_DYNAMIC_TASKS}.[/yellow]"
            )
            return []

        if not any(task.assigned_ant == "verifier" for task in tasks):
            print("[yellow]Planner did not include verifier task. Adding one.[/yellow]")
            tasks.append(
                Task(
                    title="Verify mission output",
                    description=f"Check the final result for accuracy, completeness, and usefulness: {goal}",
                    assigned_ant="verifier",
                    task_type="verification",
                )
            )

        return tasks[:MAX_DYNAMIC_TASKS]

    def _fallback_tasks(self, goal: str) -> List[Task]:
        lowered = goal.lower()

        code_keywords = [
            "code", "script", "python", "bug", "debug", "review", "refactor",
            "function", "class", "repo", "repository", "file", "folder", "directory",
            "patch", "modify", "change",
        ]

        if any(keyword in lowered for keyword in code_keywords):
            return [
                Task(
                    title="Research mission",
                    description=f"Understand the goal and frame the code/project inspection need: {goal}",
                    assigned_ant="researcher",
                    task_type="research",
                ),
                Task(
                    title="Inspect workspace files",
                    description=f"List relevant workspace files and read safe text files if useful: {goal}",
                    assigned_ant="file",
                    task_type="file_inspection",
                ),
                Task(
                    title="Create structured patch proposal",
                    description=f"Analyze available code/file context and propose structured patches as JSON only: {goal}",
                    assigned_ant="coder",
                    task_type="patch_proposal",
                ),
                Task(
                    title="Build final response",
                    description=f"Create a practical answer or implementation plan from the prior findings: {goal}",
                    assigned_ant="builder",
                    task_type="build_answer",
                ),
                Task(
                    title="Verify result",
                    description=f"Check the result for accuracy, usefulness, missing steps, and risk: {goal}",
                    assigned_ant="verifier",
                    task_type="verification",
                ),
            ]

        return [
            Task(
                title="Research mission",
                description=f"Understand the goal and gather useful context: {goal}",
                assigned_ant="researcher",
                task_type="research",
            ),
            Task(
                title="Build response",
                description=f"Create a practical answer or action plan for: {goal}",
                assigned_ant="builder",
                task_type="build_answer",
            ),
            Task(
                title="Verify result",
                description=f"Check the result for accuracy, usefulness, and missing steps: {goal}",
                assigned_ant="verifier",
                task_type="verification",
            ),
        ]


