class BaseAnt(ABC):
    def __init__(self, name: str):
        self.name = name

    @abstractmethod
    def run(self, task: Task, mission: Mission) -> str:
        pass


class ResearcherAnt(BaseAnt):
    def __init__(self, memory: SQLiteMemory, tools: ToolRegistry):
        super().__init__(name="researcher")
        self.memory = memory
        self.tools = tools

    def run(self, task: Task, mission: Mission) -> str:
        recent_memory = self.memory.format_recent_memory(
            limit=RECENT_MEMORY_LIMIT,
            max_result_chars=MEMORY_RESULT_CHARS,
        )

        relevant_memory = self.memory.format_relevant_memory(
            goal=mission.goal,
            limit=RELEVANT_MEMORY_LIMIT,
            max_result_chars=MEMORY_RESULT_CHARS,
        )

        pheromone_context = self.memory.format_pheromone_context(limit=8)

        tool_results = [
            self.tools.run_tool(
                "system_info",
                mission_id=mission.id,
                task_id=task.id,
                ant_name=self.name,
            )
        ]

        if self._should_inspect_workspace(task, mission):
            tool_results.append(
                self.tools.run_tool(
                    "list_directory",
                    mission_id=mission.id,
                    task_id=task.id,
                    ant_name=self.name,
                    path=".",
                )
            )

        tool_report = self._format_tool_report(tool_results)

        return (
            f"Researcher Ant reviewed the current mission, memory, pheromone trails, and safe context.\n\n"
            f"Current Mission:\n{mission.goal}\n\n"
            f"Assigned Task:\n{task.description}\n\n"
            f"Recent Memory:\n{recent_memory}\n\n"
            f"Relevant Memory:\n{relevant_memory}\n\n"
            f"Pheromone Trail Context:\n{pheromone_context}\n\n"
            f"Tool Context:\n{tool_report}\n\n"
            f"Research Finding:\n"
            f"The mission should be handled through specialized task execution, verified, "
            f"scored with pheromone strength, logged through the event ledger, and saved into memory. "
            f"Patch proposals may be created as structured JSON, but they must not be applied in v0.8.1."
        )

    def _should_inspect_workspace(self, task: Task, mission: Mission) -> bool:
        text = f"{mission.goal} {task.title} {task.description}".lower()

        keywords = [
            "file", "files", "folder", "folders", "directory", "directories",
            "workspace", "project", "code", "script", "python", "repo", "repository",
            "debug", "error", "log", "logs", "config", "read", "inspect", "list",
            "show", "what's here", "whats here", "what is here", "what's in",
            "whats in", "look at", "open", "tree", "structure", "patch",
        ]

        return any(keyword in text for keyword in keywords)

    def _format_tool_report(self, results: List[ToolResult]) -> str:
        blocks = []

        for result in results:
            if result.success:
                blocks.append(
                    f"Tool: {result.tool_name}\n"
                    f"Success: {result.success}\n"
                    f"Output:\n{result.output}"
                )
            else:
                blocks.append(
                    f"Tool: {result.tool_name}\n"
                    f"Success: {result.success}\n"
                    f"Error:\n{result.error}"
                )

        return "\n\n---\n\n".join(blocks)


class FileAnt(BaseAnt):
    def __init__(self, tools: ToolRegistry):
        super().__init__(name="file")
        self.tools = tools

    def run(self, task: Task, mission: Mission) -> str:
        directory_result = self.tools.run_tool(
            "list_directory",
            mission_id=mission.id,
            task_id=task.id,
            ant_name=self.name,
            path=".",
        )

        candidate_paths = []

        if self._should_attempt_file_reads(task, mission):
            candidate_paths = self._extract_candidate_paths(task, mission)

        file_reports = []

        for path in candidate_paths[:MAX_FILEANT_FILES_TO_READ]:
            read_result = self.tools.run_tool(
                "read_text_file",
                mission_id=mission.id,
                task_id=task.id,
                ant_name=self.name,
                path=path,
            )

            if read_result.success:
                file_reports.append(
                    f"File: {path}\n"
                    f"Read Success: True\n"
                    f"Content:\n{read_result.output}"
                )
            else:
                file_reports.append(
                    f"File: {path}\n"
                    f"Read Success: False\n"
                    f"Error:\n{read_result.error}"
                )

        if not file_reports:
            if self._should_attempt_file_reads(task, mission):
                file_reports.append(
                    "FileAnt detected file/code inspection intent but did not identify specific readable file paths. "
                    "It only listed the workspace structure."
                )
            else:
                file_reports.append(
                    "FileAnt did not attempt specific file reads because the task did not clearly request reading a file. "
                    "It only listed the workspace structure."
                )

        return (
            f"FileAnt performed safe read-only workspace inspection.\n\n"
            f"Mission:\n{mission.goal}\n\n"
            f"Assigned Task:\n{task.description}\n\n"
            f"Workspace Listing:\n"
            f"Success: {directory_result.success}\n"
            f"{directory_result.output if directory_result.success else directory_result.error}\n\n"
            f"File Read Reports:\n"
            + "\n\n---\n\n".join(file_reports)
            + "\n\nFileAnt did not write, modify, delete, execute, or patch any files."
        )

    def _should_attempt_file_reads(self, task: Task, mission: Mission) -> bool:
        text = f"{mission.goal} {task.title} {task.description}".lower()

        intent_keywords = [
            "read",
            "open",
            "inspect",
            "review",
            "check",
            "debug",
            "analyze",
            "look at",
            "show me",
            "this file",
            "my file",
            "script",
            "code",
            "repo",
            "repository",
            "project",
            "patch",
        ]

        return any(keyword in text for keyword in intent_keywords)

    def _extract_candidate_paths(self, task: Task, mission: Mission) -> List[str]:
        text = f"{mission.goal}\n{task.title}\n{task.description}"

        candidates = []

        quoted = re.findall(r"['\"]([^'\"]+\.[A-Za-z0-9]+)['\"]", text)
        candidates.extend(quoted)

        suffix_pattern = r"\b[\w\-/\\.]+\.(?:py|txt|md|json|yaml|yml|toml|ini|cfg|log|csv|html|css|js|ts|tsx|jsx|xml)\b"
        candidates.extend(re.findall(suffix_pattern, text))

        lowered = text.lower()

        if any(keyword in lowered for keyword in ["anthill", "this script", "main script", "python script"]):
            candidates.append("anthill.py")

        cleaned = []
        seen = set()

        for candidate in candidates:
            candidate = candidate.strip().strip(".,;:()[]{}")

            if not candidate:
                continue

            if candidate not in seen:
                cleaned.append(candidate)
                seen.add(candidate)

        return cleaned


class CoderAnt(BaseAnt):
    def __init__(self, use_ollama: bool = USE_OLLAMA, llm: Optional[OllamaClient] = None):
        super().__init__(name="coder")
        self.use_ollama = use_ollama
        self.llm = llm

    def run(self, task: Task, mission: Mission) -> str:
        code_context = self._build_code_context(mission)

        if not self.use_ollama or self.llm is None:
            return self._fallback_patch_json(task, mission, code_context)

        prompt = f"""
You are Coder Ant inside ANTHILL, a local swarm-intelligence AI harness.

Your role in v0.8.1:
Create structured patch proposals as JSON only.

Important limits:
- You do not write files.
- You do not run shell commands.
- You do not execute tests.
- You do not apply patches.
- You only propose patches for human review.

Mission goal:
{mission.goal}

Assigned coding task:
{task.title}
{task.description}

Available prior context:
{code_context}

Return ONLY valid JSON.
Do not include markdown.
Do not include explanations outside the JSON.

Required JSON format:
{{
  "summary": "Brief summary of the proposed changes.",
  "proposals": [
    {{
      "file_path": "relative/path/to/file.py",
      "change_type": "modify",
      "reason": "Why this change is recommended.",
      "risk": "Risk level and what should be reviewed.",
      "old_content": "Optional exact old content or null.",
      "new_content": "Optional proposed new content or null.",
      "requires_approval": true
    }}
  ]
}}

Allowed change_type values:
add, modify, delete, rename

Rules:
- If no safe patch can be proposed, return an empty proposals list.
- Every proposal must require approval.
- file_path must be a relative path inside the allowed workspace.
- Do not propose patches for database files, virtual environments, .git files, or cache folders.
- Do not propose absolute paths.
- Do not propose paths containing ..
- requires_approval must always be true.
- Keep old_content and new_content focused. Do not include an entire huge file unless necessary.
- Prefer small focused patches.
- Do not invent file contents if FileAnt did not provide enough context.
- If context is incomplete, explain that in the summary and use an empty proposals list.
"""

        response = self.llm.generate(prompt)

        if response.startswith("ERROR:"):
            return (
                f"{response}\n\n"
                f"{self._fallback_patch_json(task, mission, code_context)}"
            )

        return response

    def _build_code_context(self, mission: Mission) -> str:
        blocks = []

        for item in mission.tasks:
            if item.result:
                cleaned_result = self._clean_context_block(item.assigned_ant, item.result)

                blocks.append(
                    f"Task: {item.title}\n"
                    f"Ant: {item.assigned_ant}\n"
                    f"Task Type: {item.task_type}\n"
                    f"Status: {item.status.value}\n"
                    f"Result:\n{cleaned_result}"
                )

        context = "\n\n---\n\n".join(blocks) if blocks else "No prior code/file context available."

        return truncate_text(
            context,
            MAX_CODER_CONTEXT_CHARS,
            suffix="...[coder context truncated]",
        )

    def _clean_context_block(self, ant_name: str, result: str) -> str:
        if ant_name != "file":
            return result

        markers = [
            "File Read Reports:",
        ]

        for marker in markers:
            if marker in result:
                return result.split(marker, 1)[1].strip()

        return result

    def _fallback_patch_json(self, task: Task, mission: Mission, code_context: str) -> str:
        return json.dumps({
            "summary": (
                "CoderAnt fallback mode could not create a reliable structured patch because "
                "LLM generation is unavailable or insufficient context was provided."
            ),
            "proposals": []
        }, indent=2)


class BuilderAnt(BaseAnt):
    def __init__(self, use_ollama: bool = USE_OLLAMA, llm: Optional[OllamaClient] = None):
        super().__init__(name="builder")
        self.use_ollama = use_ollama
        self.llm = llm

    def run(self, task: Task, mission: Mission) -> str:
        previous_results = [
            f"{t.assigned_ant.upper()} - {t.title} ({t.task_type}):\n{t.result}"
            for t in mission.tasks
            if t.result
        ]

        previous_context = (
            "\n\n".join(previous_results)
            if previous_results
            else "No previous task context available."
        )

        previous_context = truncate_text(
            previous_context,
            MAX_PREVIOUS_CONTEXT_CHARS,
            suffix="...[previous context truncated]",
        )

        if not self.use_ollama or self.llm is None:
            return self._fallback_response(task, mission, previous_context)

        prompt = f"""
You are Builder Ant inside ANTHILL, a local swarm-intelligence AI harness.

ANTHILL concept:
A Queen agent receives a user mission, creates tasks, assigns specialized ant agents,
collects the results, verifies the output, assigns a pheromone success score, logs events, and stores memory.

Mission goal:
{mission.goal}

Your assigned task:
{task.title}
{task.description}

Previous task context:
{previous_context}

Your job:
Create a practical final response from the prior ant results.

Rules:
- Be direct.
- Be structured.
- Do not pretend to do things you cannot actually do.
- Do not claim files were written or changed.
- If CoderAnt produced patch proposals, clearly say they are proposals only.
- Explain that patch proposals require approval before any future application.
- Keep the answer useful for someone building or using a local AI harness.
"""

        response = self.llm.generate(prompt)

        if response.startswith("ERROR:"):
            fallback = self._fallback_response(task, mission, previous_context)
            return (
                f"{response}\n\n"
                f"Fallback Builder Response:\n{fallback}"
            )

        return response

    def _fallback_response(self, task: Task, mission: Mission, previous_context: str) -> str:
        return (
            f"Builder Ant created a basic non-LLM response.\n\n"
            f"Mission Goal:\n{mission.goal}\n\n"
            f"Assigned Task:\n{task.title}\n{task.description}\n\n"
            f"Previous Context:\n{previous_context}\n\n"
            f"Proposed Output:\n"
            f"1. Understand the mission.\n"
            f"2. Review any structured patch proposals.\n"
            f"3. Treat patch proposals as read-only recommendations.\n"
            f"4. Do not apply or write files yet.\n"
            f"5. Leave enough detail for the verifier to check."
        )


class VerifierAnt(BaseAnt):
    def __init__(self, use_ollama: bool = USE_OLLAMA, llm: Optional[OllamaClient] = None):
        super().__init__(name="verifier")
        self.use_ollama = use_ollama
        self.llm = llm

    def run(self, task: Task, mission: Mission) -> str:
        prior_tasks = [t for t in mission.tasks if t.id != task.id]

        completed_tasks = [t for t in prior_tasks if t.status == TaskStatus.COMPLETE]
        failed_tasks = [t for t in prior_tasks if t.status == TaskStatus.FAILED]
        output_tasks = [
            t for t in prior_tasks
            if t.assigned_ant in {"builder", "coder"} and t.result
        ]

        static_check = self._static_verify(completed_tasks, failed_tasks, output_tasks)

        if not self.use_ollama or self.llm is None:
            return static_check

        verification_context = self._build_verification_context(mission, prior_tasks)

        prompt = f"""
You are Verifier Ant inside ANTHILL, a local swarm-intelligence AI harness.

Your job:
Evaluate whether the mission output is useful, complete, and aligned with the original mission.

Mission goal:
{mission.goal}

Assigned verification task:
{task.title}
{task.description}

Static system check:
{static_check}

Task outputs to verify:
{verification_context}

Return a concise verification report.

Required format:
- Verdict: Verification Passed / Needs Improvement / Verification Failed
- Reasoning: brief explanation
- Missing Steps: list any missing items, or "None"
- Risk Notes: list risks, hallucinations, unsafe assumptions, or "None"

Rules:
- Be strict but fair.
- Do not invent facts.
- Judge the output against the mission goal.
- If the builder/coder did not actually answer the mission, say so.
- If patch proposals exist, confirm that they were not applied.
- If patch proposals exist, verify that every proposal requires approval.
- If patch proposals target unsafe paths, mark Needs Improvement or Verification Failed.
- If the mission involved code, check that the answer does not claim files were modified.
"""

        response = self.llm.generate(prompt)

        if response.startswith("ERROR:"):
            return (
                f"{static_check}\n\n"
                f"LLM verifier unavailable:\n{response}"
            )

        return response

    def _static_verify(
        self,
        completed_tasks: List[Task],
        failed_tasks: List[Task],
        output_tasks: List[Task],
    ) -> str:
        if failed_tasks:
            return (
                "Verification Failed\n"
                "Reasoning: One or more tasks failed before verification.\n"
                "Missing Steps: Resolve failed task output before finalizing.\n"
                "Risk Notes: Mission may be incomplete or partially invalid."
            )

        if not output_tasks:
            return (
                "Verification Failed\n"
                "Reasoning: No builder or coder output was found to verify.\n"
                "Missing Steps: Builder or coder output is required.\n"
                "Risk Notes: Mission result may be empty or incomplete."
            )

        if len(completed_tasks) >= 2:
            return (
                "Verification Passed\n"
                "Reasoning: Mission has completed task output and at least one builder/coder result.\n"
                "Missing Steps: None identified by static verification.\n"
                "Risk Notes: Static verification does not evaluate factual content."
            )

        return (
            "Needs Improvement\n"
            "Reasoning: Mission may not have enough completed task output.\n"
            "Missing Steps: More task output may be needed before finalizing.\n"
            "Risk Notes: Output may be incomplete."
        )

    def _build_verification_context(self, mission: Mission, prior_tasks: List[Task]) -> str:
        blocks = []

        for item in prior_tasks:
            blocks.append(
                f"Task: {item.title}\n"
                f"Ant: {item.assigned_ant}\n"
                f"Task Type: {item.task_type}\n"
                f"Status: {item.status.value}\n"
                f"Result:\n{item.result}\n"
            )

        context = "\n---\n".join(blocks)

        return truncate_text(
            context,
            MAX_VERIFIER_CONTEXT_CHARS,
            suffix="...[verification context truncated]",
        )


