#  PHEROMONE ENGINE
# ============================================================

class PheromoneEngine:
    QUALITY_BONUS_THRESHOLD = 1500

    def score_mission(self, mission: Mission) -> float:
        total_tasks = len(mission.tasks)

        if total_tasks == 0:
            return 0.0

        completed_tasks = [
            task for task in mission.tasks
            if task.status == TaskStatus.COMPLETE
        ]

        failed_tasks = [
            task for task in mission.tasks
            if task.status == TaskStatus.FAILED
        ]

        skipped_tasks = [
            task for task in mission.tasks
            if task.status == TaskStatus.SKIPPED
        ]

        builder_results = [
            task.result for task in mission.tasks
            if task.assigned_ant in {"builder", "coder"} and task.result
        ]

        verifier_results = [
            task.result for task in mission.tasks
            if task.assigned_ant == "verifier" and task.result
        ]

        builder_output = "\n".join(builder_results)
        verifier_output = "\n".join(verifier_results)

        completion_score = len(completed_tasks) / total_tasks
        failure_penalty = len(failed_tasks) * 0.25
        skipped_penalty = len(skipped_tasks) * 0.05

        score = completion_score - failure_penalty - skipped_penalty

        if len(builder_output) > self.QUALITY_BONUS_THRESHOLD:
            score += 0.10

        verdict = extract_verdict(verifier_output)

        if verdict == "failed":
            score -= 0.25
        elif verdict == "needs_improvement":
            score -= 0.10
        elif verdict == "passed":
            score += 0.05

        return max(0.0, min(1.0, round(score, 2)))


