class PatchProposalParser:
    def parse(self, raw_text: str, mission_id: str, task_id: str) -> PatchSet:
        parsed = extract_json_object(raw_text)

        summary = str(parsed.get("summary", "")).strip()
        if not summary:
            summary = "Structured patch proposal generated by CoderAnt."

        raw_proposals = parsed.get("proposals", [])

        if not isinstance(raw_proposals, list):
            raise ValueError("'proposals' must be a list.")

        if len(raw_proposals) > MAX_PATCH_PROPOSALS_PER_SET:
            raw_proposals = raw_proposals[:MAX_PATCH_PROPOSALS_PER_SET]

        proposals = []

        for item in raw_proposals:
            if not isinstance(item, dict):
                continue

            file_path = validate_safe_patch_path(str(item.get("file_path", "")).strip())

            change_type = str(item.get("change_type", "modify")).strip().lower()
            reason = str(item.get("reason", "")).strip()
            risk = str(item.get("risk", "")).strip()

            old_content = item.get("old_content")
            new_content = item.get("new_content")

            if isinstance(old_content, str):
                old_content = truncate_text(
                    old_content,
                    MAX_PATCH_CONTENT_CHARS,
                    suffix="...[old_content truncated]",
                )

            if isinstance(new_content, str):
                new_content = truncate_text(
                    new_content,
                    MAX_PATCH_CONTENT_CHARS,
                    suffix="...[new_content truncated]",
                )

            if not reason:
                raise ValueError("Patch proposal missing reason.")

            if not risk:
                risk = "Unspecified risk. Human review required."

            proposal = PatchProposal(
                file_path=file_path,
                change_type=change_type,
                reason=reason,
                risk=risk,
                old_content=old_content,
                new_content=new_content,

                # v0.8.1 hard safety rule:
                # Even if the LLM returns false, all patch proposals require approval.
                requires_approval=True,

                status=PatchStatus.PROPOSED,
            )

            proposals.append(proposal)

        return PatchSet(
            mission_id=mission_id,
            task_id=task_id,
            summary=summary,
            proposals=proposals,
        )


