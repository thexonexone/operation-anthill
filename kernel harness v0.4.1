from abc import ABC, abstractmethod
from datetime import datetime, timezone
from enum import Enum
from pathlib import Path
from typing import List, Optional, Dict, Any
from uuid import uuid4
import json
import re
import sqlite3
import requests

from pydantic import BaseModel, Field
from rich import print


# ============================================================
#  CONFIG
# ============================================================

OLLAMA_MODEL = "llama3.1:8b"
OLLAMA_HOST = "http://localhost:11434"
USE_OLLAMA = True

MAX_GOAL_LENGTH = 2000
MIN_DYNAMIC_TASKS = 3
MAX_DYNAMIC_TASKS = 6


# ============================================================
#  MODELS
# ============================================================

class TaskStatus(str, Enum):
    PENDING = "pending"
    RUNNING = "running"
    COMPLETE = "complete"
    FAILED = "failed"


class MissionStatus(str, Enum):
    CREATED = "created"
    RUNNING = "running"
    COMPLETE = "complete"
    FAILED = "failed"


class Task(BaseModel):
    id: str = Field(default_factory=lambda: str(uuid4()))
    title: str
    description: str
    assigned_ant: str
    status: TaskStatus = TaskStatus.PENDING
    result: Optional[str] = None


class Mission(BaseModel):
    id: str = Field(default_factory=lambda: str(uuid4()))
    goal: str
    tasks: List[Task] = Field(default_factory=list)
    status: MissionStatus = MissionStatus.CREATED
    final_result: Optional[str] = None
    success_score: Optional[float] = None
    created_at: datetime = Field(default_factory=lambda: datetime.now(timezone.utc))


# ============================================================
#  OLLAMA CLIENT
# ============================================================

class OllamaClient:
    def __init__(self, model: str = OLLAMA_MODEL, host: str = OLLAMA_HOST):
        self.model = model
        self.host = host.rstrip("/")

    def generate(self, prompt: str, retries: int = 2) -> str:
        url = f"{self.host}/api/generate"

        payload = {
            "model": self.model,
            "prompt": prompt,
            "stream": False,
        }

        last_error = ""

        for attempt in range(1, retries + 1):
            try:
                response = requests.post(url, json=payload, timeout=180)
                response.raise_for_status()
                data = response.json()

                output = data.get("response", "").strip()

                if not output:
                    return "Ollama returned an empty response."

                return output

            except requests.exceptions.ConnectionError:
                return (
                    "ERROR: Could not connect to Ollama. "
                    "Make sure Ollama is installed and running at http://localhost:11434."
                )

            except requests.exceptions.Timeout:
                last_error = f"ERROR: Ollama request timed out (attempt {attempt}/{retries})."

            except Exception as error:
                last_error = f"ERROR: Ollama request failed: {error} (attempt {attempt}/{retries})."

        return last_error


# ============================================================
#  MEMORY
# ============================================================

class SQLiteMemory:
    def __init__(self, db_path: str = "data/anthill_memory.db"):
        self.db_path = db_path
        Path("data").mkdir(parents=True, exist_ok=True)
        self._init_db()

    def _connect(self):
        return sqlite3.connect(self.db_path)

    def _init_db(self):
        with self._connect() as conn:
            cursor = conn.cursor()

            cursor.execute("""
                CREATE TABLE IF NOT EXISTS missions (
                    id TEXT PRIMARY KEY,
                    goal TEXT NOT NULL,
                    status TEXT NOT NULL,
                    final_result TEXT,
                    success_score REAL,
                    created_at TEXT NOT NULL,
                    saved_at TEXT NOT NULL
                )
            """)

            cursor.execute("""
                CREATE TABLE IF NOT EXISTS tasks (
                    id TEXT PRIMARY KEY,
                    mission_id TEXT NOT NULL,
                    title TEXT NOT NULL,
                    description TEXT NOT NULL,
                    assigned_ant TEXT NOT NULL,
                    status TEXT NOT NULL,
                    result TEXT,
                    FOREIGN KEY (mission_id) REFERENCES missions(id)
                )
            """)

            conn.commit()

    def save_mission(self, mission: Mission):
        with self._connect() as conn:
            cursor = conn.cursor()

            cursor.execute("""
                INSERT OR REPLACE INTO missions (
                    id, goal, status, final_result, success_score, created_at, saved_at
                )
                VALUES (?, ?, ?, ?, ?, ?, ?)
            """, (
                mission.id,
                mission.goal,
                mission.status.value,
                mission.final_result,
                mission.success_score,
                mission.created_at.isoformat(),
                datetime.now(timezone.utc).isoformat(),
            ))

            for task in mission.tasks:
                cursor.execute("""
                    INSERT OR REPLACE INTO tasks (
                        id, mission_id, title, description, assigned_ant, status, result
                    )
                    VALUES (?, ?, ?, ?, ?, ?, ?)
                """, (
                    task.id,
                    mission.id,
                    task.title,
                    task.description,
                    task.assigned_ant,
                    task.status.value,
                    task.result,
                ))

            conn.commit()

    def get_recent_missions(self, limit: int = 5) -> List[Dict[str, str]]:
        with self._connect() as conn:
            conn.row_factory = sqlite3.Row
            cursor = conn.cursor()

            cursor.execute("""
                SELECT id, goal, status, final_result, success_score, created_at, saved_at
                FROM missions
                ORDER BY saved_at DESC
                LIMIT ?
            """, (limit,))

            rows = cursor.fetchall()
            return [dict(row) for row in rows]

    def format_recent_memory(self, limit: int = 3, max_result_chars: int = 300) -> str:
        recent_missions = self.get_recent_missions(limit=limit)

        if not recent_missions:
            return "No previous mission memory found."

        memory_blocks = []

        for mission in recent_missions:
            score = mission.get("success_score")
            score_line = f"Previous Pheromone Score: {score}" if score is not None else ""

            result_summary = mission.get("final_result") or ""

            if len(result_summary) > max_result_chars:
                result_summary = result_summary[:max_result_chars].rstrip() + "...[truncated]"

            block = (
                f"Previous Goal: {mission.get('goal')}\n"
                f"Previous Status: {mission.get('status')}\n"
            )

            if score_line:
                block += f"{score_line}\n"

            block += f"Previous Result Summary:\n{result_summary}\n"
            memory_blocks.append(block)

        return "\n---\n".join(memory_blocks)


# ============================================================
#  PLANNER
# ============================================================

class Planner:
    ALLOWED_ANTS = {"researcher", "builder", "verifier"}

    def __init__(self, use_ollama: bool = USE_OLLAMA, llm: Optional[OllamaClient] = None):
        self.use_ollama = use_ollama
        self.llm = llm

    def create_tasks(self, goal: str, memory_context: str = "") -> List[Task]:
        if not self.use_ollama or self.llm is None:
            return self._fallback_tasks(goal)

        prompt = f"""
You are the Planner inside ANTHILL, a local swarm-intelligence AI harness.

ANTHILL has these available ants only:
- researcher: gathers context, reviews memory, frames the mission.
- builder: creates the main answer, code, plan, commands, or solution.
- verifier: checks output quality, missing steps, and failure risks.

Mission goal:
{goal}

Recent memory context:
{memory_context}

Your job:
Create a mission-specific task plan.

Rules:
- Return ONLY valid JSON.
- Do not include markdown.
- Do not include explanations outside the JSON.
- Create between {MIN_DYNAMIC_TASKS} and {MAX_DYNAMIC_TASKS} tasks.
- Every task must use one of these assigned_ant values only: researcher, builder, verifier.
- The final task should usually be assigned to verifier.
- Use more than one builder task only if the mission needs multiple build phases.

Required JSON format:
{{
  "tasks": [
    {{
      "title": "Short task title",
      "description": "Clear task description",
      "assigned_ant": "researcher"
    }},
    {{
      "title": "Short task title",
      "description": "Clear task description",
      "assigned_ant": "builder"
    }},
    {{
      "title": "Short task title",
      "description": "Clear task description",
      "assigned_ant": "verifier"
    }}
  ]
}}
"""

        response = self.llm.generate(prompt)

        if response.startswith("ERROR:"):
            print(f"[red]Planner failed to use Ollama:[/red] {response}")
            print("[yellow]Using fallback static task plan.[/yellow]")
            return self._fallback_tasks(goal)

        try:
            parsed = self._parse_json_response(response)
            tasks = self._tasks_from_json(parsed, goal)

            if not tasks:
                print("[yellow]Dynamic planner returned no valid task plan. Using fallback plan.[/yellow]")
                return self._fallback_tasks(goal)

            print("[bold blue]Dynamic planner created mission-specific tasks.[/bold blue]")
            return tasks

        except Exception as error:
            print(f"[yellow]Dynamic planner parse failed:[/yellow] {error}")
            print("[yellow]Using fallback static task plan.[/yellow]")
            return self._fallback_tasks(goal)

    def _parse_json_response(self, response: str) -> Dict[str, Any]:
        cleaned = response.strip()

        if cleaned.startswith("```"):
            cleaned = re.sub(r"^```(?:json)?", "", cleaned, flags=re.IGNORECASE).strip()
            cleaned = re.sub(r"```$", "", cleaned).strip()

        try:
            return json.loads(cleaned)
        except json.JSONDecodeError:
            match = re.search(r"\{.*\}", cleaned, re.DOTALL)

            if not match:
                raise ValueError("No JSON object found in planner response.")

            return json.loads(match.group(0))

    def _tasks_from_json(self, parsed: Dict[str, Any], goal: str) -> List[Task]:
        raw_tasks = parsed.get("tasks")

        if raw_tasks is None:
            print("[yellow]Planner JSON missing 'tasks' key.[/yellow]")
            return []

        if not isinstance(raw_tasks, list):
            print("[yellow]Planner JSON 'tasks' value is not a list.[/yellow]")
            return []

        tasks = []
        dropped_tasks = 0

        for item in raw_tasks[:MAX_DYNAMIC_TASKS]:
            if not isinstance(item, dict):
                dropped_tasks += 1
                continue

            title = str(item.get("title", "")).strip()
            description = str(item.get("description", "")).strip()
            assigned_ant = str(item.get("assigned_ant", "")).strip().lower()

            if assigned_ant not in self.ALLOWED_ANTS:
                dropped_tasks += 1
                print(
                    f"[yellow]Dropped planner task with invalid ant:[/yellow] "
                    f"{assigned_ant or 'missing'}"
                )
                continue

            if not title:
                title = f"{assigned_ant.title()} task"

            if not description:
                description = f"Handle part of the mission: {goal}"

            tasks.append(
                Task(
                    title=title,
                    description=description,
                    assigned_ant=assigned_ant,
                )
            )

        if dropped_tasks:
            print(f"[yellow]Planner dropped {dropped_tasks} invalid task(s).[/yellow]")

        if len(tasks) < MIN_DYNAMIC_TASKS:
            print(
                f"[yellow]Planner produced only {len(tasks)} valid task(s); "
                f"minimum is {MIN_DYNAMIC_TASKS}.[/yellow]"
            )
            return []

        if not any(task.assigned_ant == "verifier" for task in tasks):
            print("[yellow]Planner did not include verifier task. Adding one.[/yellow]")
            tasks.append(
                Task(
                    title="Verify mission output",
                    description=f"Check the final result for accuracy, completeness, and usefulness: {goal}",
                    assigned_ant="verifier",
                )
            )

        return tasks[:MAX_DYNAMIC_TASKS]

    def _fallback_tasks(self, goal: str) -> List[Task]:
        return [
            Task(
                title="Research mission",
                description=f"Understand the goal and gather useful context: {goal}",
                assigned_ant="researcher",
            ),
            Task(
                title="Build response",
                description=f"Create a practical answer or action plan for: {goal}",
                assigned_ant="builder",
            ),
            Task(
                title="Verify result",
                description=f"Check the result for accuracy, usefulness, and missing steps: {goal}",
                assigned_ant="verifier",
            ),
        ]


# ============================================================
#  PHEROMONE ENGINE
# ============================================================

class PheromoneEngine:
    QUALITY_BONUS_THRESHOLD = 1500

    def score_mission(self, mission: Mission) -> float:
        total_tasks = len(mission.tasks)

        if total_tasks == 0:
            return 0.0

        completed_tasks = [
            task for task in mission.tasks
            if task.status == TaskStatus.COMPLETE
        ]

        failed_tasks = [
            task for task in mission.tasks
            if task.status == TaskStatus.FAILED
        ]

        builder_results = [
            task.result for task in mission.tasks
            if task.assigned_ant == "builder" and task.result
        ]

        builder_output = "\n".join(builder_results)

        completion_score = len(completed_tasks) / total_tasks
        failure_penalty = len(failed_tasks) * 0.25

        score = completion_score - failure_penalty

        if len(builder_output) > self.QUALITY_BONUS_THRESHOLD:
            score += 0.10

        return max(0.0, min(1.0, round(score, 2)))


# ============================================================
#  ANTS
# ============================================================

class BaseAnt(ABC):
    def __init__(self, name: str):
        self.name = name

    @abstractmethod
    def run(self, task: Task, mission: Mission) -> str:
        pass


class ResearcherAnt(BaseAnt):
    def __init__(self, memory: SQLiteMemory):
        super().__init__(name="researcher")
        self.memory = memory

    def run(self, task: Task, mission: Mission) -> str:
        recent_memory = self.memory.format_recent_memory(limit=3, max_result_chars=500)

        return (
            f"Researcher Ant reviewed the current mission and recent memory.\n\n"
            f"Current Mission:\n{mission.goal}\n\n"
            f"Assigned Task:\n{task.description}\n\n"
            f"Recent Memory:\n{recent_memory}\n\n"
            f"Research Finding:\n"
            f"The mission should be handled through specialized task execution, verified, "
            f"scored with pheromone strength, and saved into memory so future missions can improve."
        )


class BuilderAnt(BaseAnt):
    def __init__(self, use_ollama: bool = USE_OLLAMA, llm: Optional[OllamaClient] = None):
        super().__init__(name="builder")
        self.use_ollama = use_ollama
        self.llm = llm

    def run(self, task: Task, mission: Mission) -> str:
        previous_results = [
            f"{t.assigned_ant.upper()} - {t.title}:\n{t.result}"
            for t in mission.tasks
            if t.result
        ]

        previous_context = (
            "\n\n".join(previous_results)
            if previous_results
            else "No previous task context available."
        )

        if not self.use_ollama or self.llm is None:
            return self._fallback_response(task, mission, previous_context)

        prompt = f"""
You are Builder Ant inside ANTHILL, a local swarm-intelligence AI harness.

ANTHILL concept:
A Queen agent receives a user mission, creates tasks, assigns specialized ant agents,
collects the results, verifies the output, assigns a pheromone success score, and stores memory for future missions.

Mission goal:
{mission.goal}

Your assigned task:
{task.title}
{task.description}

Previous task context:
{previous_context}

Your job:
Complete only your assigned builder task while supporting the overall mission.

Rules:
- Be direct.
- Be structured.
- Do not pretend to do things you cannot actually do.
- If commands, code, or steps are needed, include them.
- Keep the answer useful for someone building or using a local AI harness.
"""

        response = self.llm.generate(prompt)

        if response.startswith("ERROR:"):
            fallback = self._fallback_response(task, mission, previous_context)
            return (
                f"{response}\n\n"
                f"Fallback Builder Response:\n{fallback}"
            )

        return response

    def _fallback_response(self, task: Task, mission: Mission, previous_context: str) -> str:
        return (
            f"Builder Ant created a basic non-LLM response.\n\n"
            f"Mission Goal:\n{mission.goal}\n\n"
            f"Assigned Task:\n{task.title}\n{task.description}\n\n"
            f"Previous Context:\n{previous_context}\n\n"
            f"Proposed Output:\n"
            f"1. Understand the mission.\n"
            f"2. Execute the assigned builder task.\n"
            f"3. Use previous task context when useful.\n"
            f"4. Produce a practical result.\n"
            f"5. Leave enough detail for the verifier to check."
        )


class VerifierAnt(BaseAnt):
    def __init__(self):
        super().__init__(name="verifier")

    def run(self, task: Task, mission: Mission) -> str:
        # Exclude only this verifier task, not all verifier tasks.
        # This allows future missions to support more than one verifier.
        prior_tasks = [t for t in mission.tasks if t.id != task.id]

        completed_tasks = [t for t in prior_tasks if t.status == TaskStatus.COMPLETE]
        failed_tasks = [t for t in prior_tasks if t.status == TaskStatus.FAILED]
        builder_tasks = [t for t in prior_tasks if t.assigned_ant == "builder" and t.result]

        if failed_tasks:
            return (
                "Verifier Ant found one or more failed tasks before verification. "
                "The mission should be marked as failed or partially complete."
            )

        if not builder_tasks:
            return (
                "Verifier Ant found no builder output to verify. "
                "The mission may be incomplete."
            )

        if len(completed_tasks) >= 2:
            return (
                "Verifier Ant checked the mission. "
                "The mission has completed task output and a builder result suitable for final response."
            )

        return (
            "Verifier Ant found that the mission may be incomplete. "
            "More task output is needed before finalizing."
        )


# ============================================================
#  QUEEN
# ============================================================

class Queen:
    def __init__(self):
        self.memory = SQLiteMemory()
        self.llm = OllamaClient() if USE_OLLAMA else None
        self.planner = Planner(use_ollama=USE_OLLAMA, llm=self.llm)
        self.pheromones = PheromoneEngine()

        self.ants = {
            "researcher": ResearcherAnt(memory=self.memory),
            "builder": BuilderAnt(use_ollama=USE_OLLAMA, llm=self.llm),
            "verifier": VerifierAnt(),
        }

    def run_mission(self, goal: str) -> str:
        print(f"[bold cyan]Queen received mission:[/bold cyan] {goal}")

        mission = Mission(goal=goal)
        mission.status = MissionStatus.RUNNING

        memory_context = self.memory.format_recent_memory(limit=3, max_result_chars=300)
        mission.tasks = self.planner.create_tasks(goal, memory_context=memory_context)

        print(f"[dim]Mission ID: {mission.id}[/dim]")
        print(f"[dim]Created {len(mission.tasks)} tasks.[/dim]\n")

        for index, task in enumerate(mission.tasks, start=1):
            print(
                f"[yellow]Task {index}/{len(mission.tasks)} → "
                f"{task.assigned_ant} ant:[/yellow] {task.title}"
            )

            ant = self.ants.get(task.assigned_ant)

            if not ant:
                task.status = TaskStatus.FAILED
                task.result = f"No ant found for role: {task.assigned_ant}"
                print(f"[red]{task.result}[/red]")
                continue

            try:
                task.status = TaskStatus.RUNNING
                task.result = ant.run(task, mission)
                task.status = TaskStatus.COMPLETE

                print(f"[green]Task complete:[/green] {task.title}")

            except Exception as error:
                task.status = TaskStatus.FAILED
                task.result = f"Task failed with error: {error}"
                print(f"[red]{task.result}[/red]")

        if any(task.status == TaskStatus.FAILED for task in mission.tasks):
            mission.status = MissionStatus.FAILED
        else:
            mission.status = MissionStatus.COMPLETE

        mission.success_score = self.pheromones.score_mission(mission)
        mission.final_result = self._compose_final_result(mission)

        print(f"[bold blue]Pheromone score:[/bold blue] {mission.success_score}")

        self.memory.save_mission(mission)

        print("[bold magenta]Mission saved to ANTHILL memory.[/bold magenta]")

        return mission.final_result

    def _compose_final_result(self, mission: Mission) -> str:
        task_outputs = []

        for task in mission.tasks:
            task_outputs.append(
                f"Task: {task.title}\n"
                f"Ant: {task.assigned_ant}\n"
                f"Status: {task.status.value}\n"
                f"Result:\n{task.result}\n"
            )

        mission_header = (
            "Mission Complete"
            if mission.status == MissionStatus.COMPLETE
            else "Mission Failed"
        )

        score_display = (
            mission.success_score
            if mission.success_score is not None
            else "Not scored yet"
        )

        return (
            f"{mission_header}\n\n"
            f"Goal:\n{mission.goal}\n\n"
            f"Mission Status:\n{mission.status.value}\n\n"
            f"Pheromone Score:\n{score_display}\n\n"
            f"Task Results:\n\n"
            + "\n".join(task_outputs)
        )


# ============================================================
#  MAIN ENTRY POINT
# ============================================================

def main():
    print("[bold yellow]ANTHILL Core v0.4.1 online.[/bold yellow]")
    print("[dim]Type a mission for the Queen. Type 'exit' to quit.[/dim]")

    if USE_OLLAMA:
        print(f"[dim]Ollama mode: ON | Model: {OLLAMA_MODEL}[/dim]")
        print("[dim]Dynamic planning: ON[/dim]\n")
    else:
        print("[dim]Ollama mode: OFF | Using fallback static builder and planner.[/dim]")
        print("[dim]Dynamic planning: OFF[/dim]\n")

    queen = Queen()

    while True:
        user_goal = input("Mission > ").strip()

        if user_goal.lower() in ["exit", "quit"]:
            print("[bold red]ANTHILL shutting down.[/bold red]")
            break

        if not user_goal:
            continue

        if len(user_goal) > MAX_GOAL_LENGTH:
            print(f"[red]Mission too long. Please keep it under {MAX_GOAL_LENGTH} characters.[/red]")
            continue

        result = queen.run_mission(user_goal)

        print("\n[bold green]Final Result:[/bold green]")
        print(result)
        print("\n" + "-" * 60 + "\n")


if __name__ == "__main__":
    main()
