# .NET build output
bin/
obj/
*.user
*.suo

# Native kernel build output / artifacts
native/anthill_kernel/build/
native/anthill_kernel/*.so
native/anthill_kernel/*.dll
native/anthill_kernel/*.dylib

# ANTHILL local runtime state — never commit mission history, the DB, or secrets
.anthill/
*.db
*.db-wal
*.db-shm
field.key

# Published / release output — build locally with build.ps1 or build.sh
dist/
publish/

# IDE
.vs/
.idea/
*.DotSettings.user

# Secrets and env files
*.env
.env*
secrets.json

# stray files from sandbox git/test runs — never commit
FETCH_HEAD

# local SDK bootstrap helper (downloaded Microsoft installer; not project source)
dotnet-install.sh
